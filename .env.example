# =============================================================================
# KrakBot — Environment Variable Reference
# =============================================================================
# Copy this file to .env (or paste the variables into Replit Secrets) and
# adjust the values for your environment.
#
# SANDBOX / PAPER MODE (default — recommended for testing)
# Run: bash run_sandbox.sh
# =============================================================================

# ── Strategy selection ────────────────────────────────────────────────────────
# Set to "true" to activate the Bull/Bear Rotational Trading System.
# Default "false" runs the original RL/MA-crossover agent.
USE_BULL_BEAR_TRADER=true

# ── Broker mode ───────────────────────────────────────────────────────────────
# USE_PAPER_BROKER=true  → Synthetic fills (no real orders sent to Kraken).
#                          Prices are fetched live from Kraken's public API.
#                          All P&L, fees, and positions are simulated locally.
#                          Safe: no API credentials needed.
# USE_PAPER_BROKER=false → Real LiveBroker (requires API credentials below).
USE_PAPER_BROKER=true

# ── Kraken sandbox vs. live ───────────────────────────────────────────────────
# KRAKEN_SANDBOX=true  → Passes validate=true on order submissions.
#                         Kraken validates the order format but does NOT fill it.
#                         Useful when USE_PAPER_BROKER=false for order testing.
# KRAKEN_SANDBOX=false → Real order submission (USE_PAPER_BROKER must also be false).
KRAKEN_SANDBOX=true

# ── Bot mode ──────────────────────────────────────────────────────────────────
# BOT_MODE=live → Start the live / paper trading loop (default).
# BOT_MODE=sim  → Run the multi-agent simulation (no Kraken API calls).
BOT_MODE=live

# ── Starting paper balance ────────────────────────────────────────────────────
# USD amount for the simulated paper account.
# Only used when USE_PAPER_BROKER=true.
# INITIAL_BALANCE is set in project/config/config.py (default $10,000).

# ── Kraken API credentials ────────────────────────────────────────────────────
# Required ONLY when USE_PAPER_BROKER=false.
# The paper broker fetches public prices without credentials.
# KRAKEN_API_KEY=your-api-key-here
# KRAKEN_API_SECRET=your-api-secret-here

# ── Going live: how to add real API keys ──────────────────────────────────────
#
# When you are ready to trade with real money, follow these steps:
#
# Step 1 — Create a Kraken API key
#   • Log in to kraken.com → Security → API → Add Key
#   • Give it a name (e.g. "KrakBot live")
#   • Enable ONLY these permissions:
#       ✅  Query Funds
#       ✅  Query Open Orders & Trades
#       ✅  Create & Modify Orders
#       ✅  Cancel/Close Orders
#       ❌  Withdraw Funds    ← DO NOT enable — not required
#   • Optional: whitelist the server IP address for extra safety
#   • Copy both the API Key and the Private Key (shown only once)
#
# Step 2 — Run the setup script
#   ./setup_keys.sh
#   This writes your key and secret to .env (gitignored — never committed)
#   and tests them against Kraken's /0/private/Balance endpoint.
#
# Step 3 — Go live
#   ./go_live.sh
#   This validates credentials, shows the current ETP market status, and
#   requires you to type "GOLIVE" to confirm before sending any real orders.
#   Set WAIT_FOR_ETP_MARKET=true to auto-wait for 09:30 ET:
#     WAIT_FOR_ETP_MARKET=true ./go_live.sh
#
# Step 4 — Replit Secrets (alternative to .env)
#   If running on Replit, add KRAKEN_API_KEY and KRAKEN_API_SECRET as
#   Replit Secrets instead of using a .env file.  The bot reads both.
#
# To switch back to paper trading at any time:
#   ./run_sandbox.sh   — no API keys needed, no real orders

# ── Futures (disabled by default; US residents cannot trade Kraken Futures) ──
# ENABLE_FUTURES=false

# ── BTC breakout detection ────────────────────────────────────────────────────
# BTC_ATH_TARGET: absolute price level for the ATH bonus signal (Component 1).
# The bot also scores uptrends via a rolling-high mechanism (Component 2) that
# works from ANY price — so the bot will start trading from $74 K upward without
# needing to touch this value.  Set to 0 to disable the absolute check entirely.
BTC_ATH_TARGET=100000

# BTC_BULL_RUN_FLOOR: minimum BTC price before the bot enters any bull phase.
# Protects against buying into dead-cat bounces during a true bear market.
# Set this slightly below the current market price when starting the bot.
# Example: BTC at $74 K → set floor to $65 000 (leaves ~12% safety margin).
BTC_BULL_RUN_FLOOR=65000

# BREAKOUT_CONFIDENCE_MIN: rolling confidence threshold to exit accumulation.
# Lowered from 0.60 to 0.55 to account for the ATH component (weight 0.20)
# scoring zero when BTC is below $100 K.  Raise this to be more conservative.
BREAKOUT_CONFIDENCE_MIN=0.55

# BTC_ROLLING_HIGH_WINDOW: bars in the look-back window for rolling-max detection.
# At 1 tick/sec (default), 60 bars ≈ 1 minute.  Increase for smoother signals.
BTC_ROLLING_HIGH_WINDOW=60

# BTC_ROLLING_HIGH_HOLD: consecutive bars above rolling max before full score.
BTC_ROLLING_HIGH_HOLD=2


# ── Asset allowlist (IMPORTANT — read this before enabling API permissions) ───
#
# This bot trades ONLY the crypto assets and crypto ETPs listed in
# APPROVED_ASSETS inside project/broker/broker.py:
#
#   Spot crypto : BTC, ETH, SOL, XRP, LINK, HBAR, XLM, AVAX
#   Crypto ETPs : ETHU (ETH 2× Long), ETHD (ETH 2× Short),
#                 SLON (SOL 2× Long), XXRP (XRP 2× Long), SETH (ETH 1× Short)
#
# Kraken lets you enable "Allow trading of stocks and ETFs" in your API key
# settings — but the bot's allowlist check fires BEFORE the order reaches
# Kraken, so even if that permission is active it is irrelevant.  Any asset
# not in the list above is rejected with a clear log message and never
# submitted to the API.
#
# Summary:
#   API key stock-trading permission = ON  → still blocked by bot's allowlist
#   API key stock-trading permission = OFF → also blocked (redundant safety)
#
# You do NOT need to enable stock-trading permission in your API key.
# Only the standard "Query" + "Trade" Kraken permissions are required.
#
# There is NO environment variable to disable this allowlist.  It is a
# hard-coded safety guarantee — not a configuration option.



# USE_RL_AGENT=false
# KRAKBOT_CHECKPOINT_PATH=/path/to/rl_checkpoint.pt

# ── Bear market short-stack sizes ─────────────────────────────────────────────
# During bear_market phase the bot opens two short-ETF instruments:
#   ETHD (2× inverse ETH ETP) — aggressive tier, sized at BEAR_SHORT_MIN (15%)
#   SETH (1× inverse ETH ETP) — conservative tier, sized at SETH_SHORT_MIN (5%)
# Together they produce a blended ~1.6× effective inverse position that is
# less volatile than ETHD alone while still capturing meaningful downside.
# Both are also used by the hedge overlay (caps: HEDGE_SHORT_MAX, HEDGE_SETH_MAX).
# Override if you want a lighter or heavier short stack:
# BEAR_SHORT_MIN=0.15
# BEAR_SHORT_MAX=0.25
# SETH_SHORT_MIN=0.05
# SETH_SHORT_MAX=0.08
# HEDGE_SHORT_MAX=0.08   # ETHD cap in overlay
# HEDGE_SETH_MAX=0.04    # SETH cap in overlay

# ── Risk limits ───────────────────────────────────────────────────────────────
# MAX_DAILY_LOSS_PCT=0.10    # 10% daily equity stop-loss (default)
# LIMIT_ORDER_TOLERANCE=0.001  # 0.1% from mid-price for limit orders
# PAPER_SLIPPAGE=0.0005       # 0.05% synthetic fill slippage (default)

# ── Monitoring intervals ──────────────────────────────────────────────────────
# HEALTH_METRICS_INTERVAL=60  # seconds between health metric logs
# ALERTING_INTERVAL=60        # seconds between alerting loop runs

# ── Scheduling / ETP market hours ─────────────────────────────────────────────
#
# The bot trades crypto spot assets 24/7 (BTC, ETH, SOL, XRP, HBAR, LINK, XLM).
# ETP/ETF hedge positions (ETHU, ETHD, SLON, XXRP, SETH) are only opened during
# US ETP market hours: Mon-Fri 09:30-16:30 Eastern.  Outside those hours the
# hedge overlay and leveraged-ETF entries are automatically skipped; all other
# strategy logic (crypto spot trades, signal computation, phase transitions)
# continues normally.
#
# To start the bot with a delay, pass one of these to run_sandbox.sh:
#
#   START_DELAY_HOURS=11      — wait exactly 11 hours then start
#   WAIT_FOR_ETP_MARKET=true  — auto-calculate time until next 09:30 ET and wait
#
# Examples:
#   START_DELAY_HOURS=11 bash run_sandbox.sh
#   WAIT_FOR_ETP_MARKET=true bash run_sandbox.sh
#
# START_DELAY_HOURS=
# WAIT_FOR_ETP_MARKET=false
