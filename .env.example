# =============================================================================
# Krakbot — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control — it contains secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Kraken API Credentials
# -----------------------------------------------------------------------------
# Generate at: https://www.kraken.com/u/settings/api
# Required permissions: Query Funds, Query/Create/Cancel Orders, Spot Trading
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# Futures credentials (separate from spot — only needed if ENABLE_FUTURES=True)
# KRAKEN_FUTURES_API_KEY=your_futures_key_here
# KRAKEN_FUTURES_API_SECRET=your_futures_secret_here


# -----------------------------------------------------------------------------
# Trading Mode
# -----------------------------------------------------------------------------
# BOT_MODE: "live" connects to Kraken API; "sim" runs offline simulation
BOT_MODE=live

# KRAKEN_SANDBOX: true = validate orders server-side (no fills); false = live
KRAKEN_SANDBOX=true

# USE_PAPER_BROKER: true = synthetic fills, no real orders; false = live orders
USE_PAPER_BROKER=true

# USE_RL_AGENT: true = use trained RL actor; false = use MA crossover strategy
USE_RL_AGENT=false

# Optional path to trained actor checkpoint (default: checkpoints/krakbot_actor.pt)
# KRAKBOT_CHECKPOINT_PATH=/path/to/krakbot_actor.pt


# -----------------------------------------------------------------------------
# Safety Limits
# -----------------------------------------------------------------------------
# Maximum daily loss as a fraction of starting equity (0.10 = 10%)
MAX_DAILY_LOSS_PCT=0.10

# Per-asset notional cap per order in USD
MAX_NOTIONAL_PER_ASSET=50.0

# Total portfolio notional cap in USD
MAX_TOTAL_NOTIONAL=200.0

# Limit-order tolerance: how far from mid-price the limit is placed (0.001 = 0.1%)
LIMIT_ORDER_TOLERANCE=0.001

# Paper mode slippage as a fraction (0.0005 = 0.05%)
PAPER_SLIPPAGE=0.0005


# -----------------------------------------------------------------------------
# ETF Hedging & Amplification
# -----------------------------------------------------------------------------
# Enable/disable the ETF overlay layer entirely
ENABLE_ETF_TRADING=true

# Maximum fraction of portfolio equity for short-ETF hedging (SETH, ETHD)
ETF_HEDGE_CAP=0.30

# Maximum fraction of portfolio equity for long-ETF amplification (XXRP, SLON, ETHU)
ETF_AMPLIFY_CAP=0.30

# Total combined ETF cap (hedge + amplify must not exceed this)
# Portfolio cap formula: (|SETH|+|ETHD|+|XXRP|+|SLON|+|ETHU|) / equity <= 0.30
ETF_TOTAL_CAP=0.30


# -----------------------------------------------------------------------------
# Market Hours (ET timezone) — affects ETF order types only
# Crypto spot trading (BTC, ETH, SOL, …) runs 24/7 regardless of these settings
# -----------------------------------------------------------------------------
TRADING_TIMEZONE=America/New_York

# Regular market hours — market orders allowed
MARKET_HOURS_START=09:30
MARKET_HOURS_END=16:00

# Extended hours — limit orders only (no market orders)
PREMARKET_START=04:00
AFTERHOURS_END=20:00


# -----------------------------------------------------------------------------
# Health Monitoring & Rate Limiting
# -----------------------------------------------------------------------------
# Interval (seconds) between health metric snapshots
HEALTH_METRICS_INTERVAL=60

# Interval (seconds) between alert evaluations
ALERTING_INTERVAL=60
