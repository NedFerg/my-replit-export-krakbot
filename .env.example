# =============================================================================
# Krakbot — environment configuration template
# =============================================================================
# Copy this file to .env (or set these as environment/Replit Secrets) and
# fill in your values before running the bot.
#
# NEVER commit a .env file with real credentials to source control.
#
# ⚡ NO MINIMUM CAPITAL REQUIREMENT ⚡
# The bot works at ANY starting amount: $1, $10, $100, $1k, $10k, $50k+
# Position sizes scale proportionally — the same strategy code runs at all
# capital levels without any code changes.
# =============================================================================

# -----------------------------------------------------------------------------
# Kraken Spot API credentials
# Required for: live price feeds, balance reads, order placement
# Generate at: https://www.kraken.com/u/settings/api
#
# Required permissions:
#   - Query Funds
#   - Query Open Orders & Trades
#   - Query Closed Orders & Trades
#   - Create & Modify Orders
#   - Cancel/Close Orders
#   - Access WebSocket API (optional — for real-time price feeds)
#   - Spot trading (BTC, ETH, SOL, XRP, LINK, AVAX, HBAR, XLM, ETHD, SETH)
# -----------------------------------------------------------------------------
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# -----------------------------------------------------------------------------
# Sandbox / paper mode
# KRAKEN_SANDBOX=true  → send validate=true on all orders (no real fills)
# KRAKEN_SANDBOX=false → live order execution (USE WITH CAUTION)
# -----------------------------------------------------------------------------
KRAKEN_SANDBOX=true

# Use the synthetic paper broker (no real HTTP orders, PnL tracked in memory)
# Set to false to use the real Kraken sandbox via validate=true
USE_PAPER_BROKER=true

# Starting balance for the paper broker (USD)
INITIAL_BALANCE=10000

# -----------------------------------------------------------------------------
# Kraken Futures (DISABLED for US users — do not enable)
# Futures trading is not available to US residents on Kraken until further
# legislation passes.  The futures architecture is preserved but all code paths
# are suppressed when ENABLE_FUTURES=False (the class-level default).
# DO NOT change the class constant unless you are outside the US.
# -----------------------------------------------------------------------------
# KRAKEN_FUTURES_API_KEY=    (leave blank — not needed while futures are disabled)
# KRAKEN_FUTURES_API_SECRET= (leave blank — not needed while futures are disabled)

# =============================================================================
# DYNAMIC CAPITAL SCALING — works at ANY amount, NO minimums
# =============================================================================
#
# TOTAL_TRADING_CAPITAL is the USD amount the bot is allowed to deploy.
# There is NO minimum.  The bot will work with $1, $10, or $50 000+.
# Position sizes are calculated as: capital × RISK_MAX_POSITION_SIZE_PCT
#
# Example configs for different starting capitals:
#
#   $1    → TOTAL_TRADING_CAPITAL=1     capital_per_trade ≈ $0.15
#   $10   → TOTAL_TRADING_CAPITAL=10    capital_per_trade ≈ $1.50
#   $50   → TOTAL_TRADING_CAPITAL=50    capital_per_trade ≈ $7.50
#   $100  → TOTAL_TRADING_CAPITAL=100   capital_per_trade ≈ $15.00
#   $500  → TOTAL_TRADING_CAPITAL=500   capital_per_trade ≈ $75.00
#   $1k   → TOTAL_TRADING_CAPITAL=1000  capital_per_trade ≈ $150.00
#   $5k   → TOTAL_TRADING_CAPITAL=5000  capital_per_trade ≈ $750.00
#   $10k  → TOTAL_TRADING_CAPITAL=10000 capital_per_trade ≈ $1500.00
#   $50k  → TOTAL_TRADING_CAPITAL=50000 capital_per_trade ≈ $7500.00
#
# If unset, the bot queries your Kraken account balance automatically.
# -----------------------------------------------------------------------------
TOTAL_TRADING_CAPITAL=50

# =============================================================================
# RISK PARAMETERS — all scale with TOTAL_TRADING_CAPITAL
# =============================================================================

# Maximum fraction of capital to risk on a single trade (0.15 = 15%).
# This is the primary lever for position sizing.
RISK_MAX_POSITION_SIZE_PCT=0.15

# Hard cap on USD notional per trade.
# Set to 0 to derive automatically: TOTAL_TRADING_CAPITAL × RISK_MAX_POSITION_SIZE_PCT
# Increase proportionally for larger accounts (e.g. 1000 for a $10k account).
RISK_MAX_NOTIONAL_USD=0

# Maximum daily loss as a fraction of day-start capital (0.10 = 10%).
# When breached, new trades are paused until the next UTC day.
# The bot does NOT stop — it resumes automatically the following day.
RISK_MAX_DAILY_DRAWDOWN_PCT=0.10

# =============================================================================
# EXPONENTIAL GROWTH — profit reinvestment
# =============================================================================
#
# When cumulative realised profits exceed this fraction of the previous
# reinvestment baseline, capital_per_trade is automatically increased to
# reflect the larger portfolio.  This creates a compounding effect.
#
# Example: with $100 starting capital and threshold=0.25:
#   - After $25 profit → capital grows to $125, capital_per_trade → $18.75
#   - After another $31.25 profit → capital grows to $156.25, etc.
#
# Works at ALL capital levels ($1+).
# -----------------------------------------------------------------------------
REINVESTMENT_PROFIT_THRESHOLD_PCT=0.25

# =============================================================================
# LIVE TRADING TOGGLE
# =============================================================================
# Set to true to place real orders on Kraken.
# Default is false (paper/simulation mode) for safety.
# Toggle from DigitalOcean console:
#   export ENABLE_LIVE_TRADING=true && python3 project_scripts/trading_bot_runner_v2.py
ENABLE_LIVE_TRADING=false

# =============================================================================
# SHORT ETF TRADING (SETH / ETHD) — ON by default
# =============================================================================
#
# When enabled, the bot rotates capital into ETHD (1× short ETH) or
# SETH (2× short ETH) on Kraken when a bearish signal triggers.
#
# MARKET HOURS: SETH/ETHD only trade Monday–Friday, 9:30 AM–4:30 PM EST.
#   - Outside those hours, ETF shorts are automatically skipped.
#   - Spot ETH trading is NEVER affected by market hours (crypto is 24/7).
#
# WEEKEND HOLDING: if SETH/ETHD are held at Friday market close they are
#   held over the weekend.  Positions close only on a bull signal or when
#   the drawdown limit is hit — there is NO forced Friday EOD close.
#
# NO MARGIN / NO FUTURES: strategy uses spot ETFs only (legal in US).
#
# To disable from DigitalOcean console (spot trading continues normally):
#   export ENABLE_SHORT_ETF_TRADING=false
#
# To re-enable:
#   export ENABLE_SHORT_ETF_TRADING=true
# -----------------------------------------------------------------------------
ENABLE_SHORT_ETF_TRADING=true

# Maximum combined allocation to ETF hedging positions (fraction of equity)
# e.g. 0.30 = 30% of portfolio — prevents over-hedging
MAX_ETF_ALLOCATION=0.30

# Minimum USD notional per ETF order (skip dust trades)
ETF_MIN_ORDER_USD=5.0

# Limit order tolerance for ETF orders during extended hours
# buy  → mid × (1 + tolerance); sell → mid × (1 - tolerance)
ETF_LIMIT_TOLERANCE=0.001

# -----------------------------------------------------------------------------
# ETF hedging layer (legacy toggle, superseded by ENABLE_SHORT_ETF_TRADING)
# -----------------------------------------------------------------------------
ENABLE_ETF_HEDGING=true

# =============================================================================
# MARKET HOURS CONFIGURATION
# =============================================================================
# All times are interpreted in the TRADING_TIMEZONE timezone.
#
# SETH/ETHD market schedule (US Eastern):
#   Regular hours  09:30–16:00 ET  Mon–Fri  → market orders permitted
#   Pre-market     04:00–09:30 ET           → limit orders only (if enabled)
#   After-hours    16:00–20:00 ET           → limit orders only (if enabled)
#   Closed         20:00–04:00 ET + weekends → no ETF orders
#
# Per the project spec, ETF shorts are ONLY executed during regular hours
# (ALLOW_PREMARKET and ALLOW_AFTER_HOURS are kept false for safety).
# Crypto spot always trades 24/7 regardless of these settings.
# -----------------------------------------------------------------------------
TRADING_TIMEZONE=America/New_York
ALLOW_PREMARKET=false
ALLOW_AFTER_HOURS=false

# Hour (ET) at which the after-hours ETF session ends (default: 20 = 8 PM)
AFTER_HOURS_END_HOUR=20

# =============================================================================
# RL AGENT
# =============================================================================

# Enable the RL actor (requires a trained checkpoint at KRAKBOT_CHECKPOINT_PATH)
# Set to false to use the deterministic MA crossover strategy instead
USE_RL_AGENT=false

# Path to the trained checkpoint file
# KRAKBOT_CHECKPOINT_PATH=project/checkpoints/krakbot_actor.pt

# MA crossover strategy parameters (active when USE_RL_AGENT=false)
MA_SHORT_WINDOW=5
MA_LONG_WINDOW=20
MA_LONG_TARGET=0.02

# =============================================================================
# TRADING PAIRS — IMPORTANT: only official Kraken canonical symbols work
# =============================================================================
#
# Kraken requires exact canonical pair codes for its API. Common short aliases
# such as BTCUSD, ETHUSD, XRPUSD, or XLMUSD are NOT accepted and will cause
# "EQuery:Unknown asset pair" errors in live mode.
#
# Use ONLY the symbols in the list below. Copying any other ticker format will
# break the live price feed and prevent the bot from placing orders.
#
# Official Kraken spot-USD pair symbols:
#   XXBTZUSD  — BTC/USD
#   XETHZUSD  — ETH/USD
#   SOLUSD    — SOL/USD
#   XXRPZUSD  — XRP/USD
#   XXLMZUSD  — XLM/USD
#   AVAXUSD   — AVAX/USD
#   HBARUSD   — HBAR/USD
#   LINKUSD   — LINK/USD
#
# To trade a subset, remove unwanted pairs from the comma-separated list.
# Do NOT substitute alternative formats — they will not work on Kraken.
# -----------------------------------------------------------------------------
TRADING_PAIRS=XXBTZUSD,XETHZUSD,SOLUSD,XXRPZUSD,XXLMZUSD,AVAXUSD,HBARUSD,LINKUSD

# =============================================================================
# SAFETY / OPERATIONAL PARAMETERS
# =============================================================================

# Daily loss cap as a fraction of starting equity (e.g. 0.10 = 10%)
MAX_DAILY_LOSS_PCT=0.10

# Limit order tolerance for crypto spot orders
LIMIT_ORDER_TOLERANCE=0.001

# Health metrics and alerting intervals (seconds)
HEALTH_METRICS_INTERVAL=60
ALERTING_INTERVAL=60

# Paper broker fill slippage (fraction, e.g. 0.0005 = 0.05%)
PAPER_SLIPPAGE=0.0005
